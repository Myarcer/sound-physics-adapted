{
    "version": 1,
    "patches": {},
    "settings": [
        { "type": "separator", "title": "General" },
        { "code": "Enabled",                       "type": "boolean", "default": true,   "ingui": "Master Enable",              "comment": "Master enable/disable for all Sound Physics features." },

        { "type": "separator", "title": "Occlusion" },
        { "code": "MaxOcclusion",                  "type": "float",   "default": 10.0,   "ingui": "Max Occlusion",              "comment": "Maximum total occlusion value. Higher = more muffling possible.",              "range": { "min": 0.0,    "max": 30.0,   "step": 0.5   } },
        { "code": "OcclusionPerSolidBlock",        "type": "float",   "default": 1.0,    "ingui": "Occlusion Per Solid Block",  "comment": "Occlusion added per solid block hit. Higher = each block muffles more.",       "range": { "min": 0.0,    "max": 5.0,    "step": 0.05  } },
        { "code": "BlockAbsorption",               "type": "float",   "default": 1.0,    "ingui": "Block Absorption",           "comment": "Absorption coefficient for lowpass filter. Higher = more aggressive muffling.", "range": { "min": 0.0,    "max": 5.0,    "step": 0.05  } },
        { "code": "MaxOcclusionRays",              "type": "integer", "default": 16,     "ingui": "Occlusion Ray Count",        "comment": "Number of raycast iterations. Higher = more accurate but slower.",            "range": { "min": 1,      "max": 64,     "step": 1     } },
        { "code": "MinLowPassFilter",              "type": "float",   "default": 0.001,  "ingui": "Min Lowpass Filter",         "comment": "Minimum lowpass filter value (0=silent, 1=no filter). Prevents total silence.", "range": { "min": 0.0,    "max": 0.1,    "step": 0.001 } },
        { "code": "OcclusionVariation",            "type": "float",   "default": 0.35,   "ingui": "Occlusion Variation",        "comment": "Multi-ray spread for soft occlusion edges. 0=single ray, 0.35=recommended.",  "range": { "min": 0.0,    "max": 1.0,    "step": 0.05  } },

        { "type": "separator", "title": "Reverb" },
        { "code": "EnableCustomReverb",            "type": "boolean", "default": true,   "ingui": "Enable Custom Reverb",       "comment": "Enable the multi-slot EAX reverb system. Replaces vanilla reverb." },
        { "code": "DisableVanillaReverb",          "type": "boolean", "default": true,   "ingui": "Disable Vanilla Reverb",     "comment": "Disable default SetReverb(). Required for custom reverb without interference." },
        { "code": "ReverbRayCount",                "type": "integer", "default": 32,     "ingui": "Reverb Ray Count",           "comment": "Rays cast for reverb calculation. More rays = more accurate but slower.",      "range": { "min": 4,      "max": 128,    "step": 4     } },
        { "code": "ReverbBounces",                 "type": "integer", "default": 4,      "ingui": "Reverb Bounces",             "comment": "Ray bounces for reverb. More bounces = longer reverb tails.",               "range": { "min": 1,      "max": 16,     "step": 1     } },
        { "code": "ReverbMaxDistance",             "type": "float",   "default": 256.0,  "ingui": "Reverb Max Distance",        "comment": "Maximum distance for reverb ray detection (blocks).",                        "range": { "min": 32.0,   "max": 512.0,  "step": 16.0  } },
        { "code": "ReverbGain",                    "type": "float",   "default": 1.0,    "ingui": "Reverb Gain",                "comment": "Master reverb gain multiplier. 1.0=normal, 0.5=half, 2.0=double.",           "range": { "min": 0.0,    "max": 3.0,    "step": 0.05  } },

        { "type": "separator", "title": "Submersion Audio" },
        { "code": "ReplaceVanillaLowpass",         "type": "boolean", "default": true,   "ingui": "Replace Vanilla Lowpass",    "comment": "Replace default underwater/lava lowpass. Stacks properly with occlusion." },
        { "code": "UnderwaterFilterValue",         "type": "float",   "default": 0.08,   "ingui": "Underwater Filter",          "comment": "Lowpass filter when fully underwater (0=silent, 1=no effect).",              "range": { "min": 0.001,  "max": 1.0,    "step": 0.005 } },
        { "code": "UnderwaterFilterAffectsMusic",  "type": "boolean", "default": false,  "ingui": "Filter Affects Music",       "comment": "Whether underwater filter muffles music sounds." },
        { "code": "UnderwaterPitchOffset",         "type": "float",   "default": -0.15,  "ingui": "Underwater Pitch Offset",    "comment": "Pitch offset when underwater (-1 to 1). Negative = lower pitch.",           "range": { "min": -1.0,   "max": 1.0,    "step": 0.01  } },
        { "code": "UnderwaterPitchAffectsMusic",   "type": "boolean", "default": false,  "ingui": "Pitch Affects Music",        "comment": "Whether underwater pitch offset affects music sounds." },
        { "code": "UnderwaterReverbCutoff",        "type": "float",   "default": 0.4,    "ingui": "Underwater Reverb Cutoff",   "comment": "Reverb HF cutoff multiplier when underwater (0-1). Lower = duller reverb.", "range": { "min": 0.0,    "max": 1.0,    "step": 0.05  } },
        { "code": "UnderwaterReverbMultiplier",    "type": "float",   "default": 0.3,    "ingui": "Underwater Reverb Gain",     "comment": "Reverb gain multiplier when underwater (0=no reverb, 1=full reverb).",     "range": { "min": 0.0,    "max": 1.0,    "step": 0.05  } },
        { "code": "EnableLavaFilter",              "type": "boolean", "default": true,   "ingui": "Enable Lava Filter",         "comment": "Enable separate lava submersion filter with heavier values than water." },
        { "code": "LavaFilterValue",               "type": "float",   "default": 0.02,   "ingui": "Lava Filter",                "comment": "Lowpass filter when submerged in lava. Much heavier than water.",           "range": { "min": 0.001,  "max": 0.5,    "step": 0.005 } },
        { "code": "LavaPitchOffset",               "type": "float",   "default": -0.30,  "ingui": "Lava Pitch Offset",          "comment": "Pitch offset when submerged in lava. Deeper shift than water.",            "range": { "min": -1.0,   "max": 1.0,    "step": 0.01  } },
        { "code": "LavaReverbCutoff",              "type": "float",   "default": 0.1,    "ingui": "Lava Reverb Cutoff",         "comment": "Reverb HF cutoff multiplier when in lava. Near-zero = almost no HF reverb.", "range": { "min": 0.0,   "max": 1.0,    "step": 0.05  } },
        { "code": "LavaReverbMultiplier",          "type": "float",   "default": 0.05,   "ingui": "Lava Reverb Gain",           "comment": "Reverb gain multiplier when in lava. Near-zero = sound barely reverberates.", "range": { "min": 0.0,  "max": 1.0,    "step": 0.05  } },

        { "type": "separator", "title": "Sound Path Repositioning" },
        { "code": "EnableSoundRepositioning",      "type": "boolean", "default": true,   "ingui": "Enable Repositioning",       "comment": "Reposition sounds toward openings (doors, windows) when occluded." },
        { "code": "EnablePathMuffle",              "type": "boolean", "default": true,   "ingui": "Enable Path Muffle",         "comment": "Path-based muffle from weighted average occlusion through openings." },
        { "code": "PermeationBase",                "type": "float",   "default": 0.4,    "ingui": "Permeation Base",            "comment": "Permeation exponential falloff base. Lower = more attenuation per occlusion unit.", "range": { "min": 0.0, "max": 1.0, "step": 0.05 } },
        { "code": "MinRepositionOffset",           "type": "float",   "default": 0.5,    "ingui": "Min Reposition Offset",      "comment": "Minimum offset (blocks) before repositioning applies. Prevents jitter.",  "range": { "min": 0.0,    "max": 4.0,    "step": 0.1   } },
        { "code": "PermeationOcclusionThreshold",  "type": "float",   "default": 1.5,    "ingui": "Permeation Threshold",       "comment": "Occlusion threshold separating open paths from through-wall paths.",      "range": { "min": 0.0,    "max": 10.0,   "step": 0.1   } },

        { "type": "separator", "title": "Sound Overrides" },
        { "code": "EnableSoundOverrides",          "type": "boolean", "default": true,   "ingui": "Enable Sound Overrides",     "comment": "Master toggle for sound file overrides. When false, all sounds use vanilla files." },
        { "code": "OverrideBeehiveSound",          "type": "boolean", "default": true,   "ingui": "Override Beehive Sound",     "comment": "Override vanilla beehive-wild.ogg with improved version. Requires EnableSoundOverrides." },
        { "code": "OverrideLightningSound",       "type": "boolean", "default": true,   "ingui": "Override Lightning Sound",   "comment": "Override vanilla lightning-nodistance.ogg with louder version. Requires EnableSoundOverrides." },

        { "type": "separator", "title": "Resonator Enhancements" },
        { "code": "EnableResonatorFix",            "type": "boolean", "default": true,   "ingui": "Enable Resonator Fix",       "comment": "Resonator enhancements: pause/resume (Shift+RMB), multi-client sync." },
        { "code": "EnableCarryOnCompat",           "type": "boolean", "default": true,   "ingui": "Carry On Compat",            "comment": "Music continues playing while carrying a resonator (boombox). Requires Carry On mod." },

        { "type": "separator", "title": "Weather Audio" },
        { "code": "EnableWeatherEnhancement",      "type": "boolean", "default": true,   "ingui": "Enable Weather Enhancement", "comment": "Replace default weather loops with enclosure-aware lowpass filtering." },
        { "code": "WeatherLPFMinCutoff",           "type": "float",   "default": 300.0,  "ingui": "Rain LPF Min Cutoff (Hz)",   "comment": "Min LPF cutoff for rain when fully enclosed. 300Hz = bass rumble only.",  "range": { "min": 20.0,   "max": 2000.0, "step": 10.0  } },
        { "code": "WeatherLPFMaxCutoff",           "type": "float",   "default": 22000.0,"ingui": "Rain LPF Max Cutoff (Hz)",   "comment": "Max LPF cutoff outdoors. 22000 = full spectrum.",                          "range": { "min": 8000.0, "max": 22000.0,"step": 500.0 } },
        { "code": "WeatherVolumeLossMax",          "type": "float",   "default": 0.6,    "ingui": "Rain Volume Loss Max",       "comment": "Max volume reduction for rain at full enclosure (0-1). Supplementary to LPF.", "range": { "min": 0.0,   "max": 1.0,    "step": 0.05  } },
        { "code": "HailLPFMinCutoff",              "type": "float",   "default": 250.0,  "ingui": "Hail LPF Min Cutoff (Hz)",   "comment": "Min LPF cutoff for hail when fully enclosed. Hail is high-frequency.",   "range": { "min": 20.0,   "max": 2000.0, "step": 10.0  } },
        { "code": "WindLPFMinCutoff",              "type": "float",   "default": 600.0,  "ingui": "Wind LPF Min Cutoff (Hz)",   "comment": "Min LPF cutoff for wind when fully enclosed. Wind bass persists more than rain.", "range": { "min": 20.0, "max": 4000.0, "step": 10.0 } },
        { "code": "TrembleLPFMinCutoff",           "type": "float",   "default": 80.0,   "ingui": "Tremble LPF Min Cutoff (Hz)","comment": "Min LPF cutoff for tremble when fully enclosed. Tremble is sub-bass content.", "range": { "min": 20.0, "max": 500.0,  "step": 5.0   } },

        { "type": "separator", "title": "Positional Weather" },
        { "code": "EnablePositionalWeather",       "type": "boolean", "default": true,   "ingui": "Enable Positional Weather",  "comment": "Place directional rain/hail/wind sources at detected openings. Requires EnableWeatherEnhancement." },
        { "code": "EnablePositionalWind",          "type": "boolean", "default": true,   "ingui": "Enable Positional Wind",     "comment": "Positional wind sources at openings. Requires EnablePositionalWeather." },
        { "code": "EnablePositionalHail",          "type": "boolean", "default": true,   "ingui": "Enable Positional Hail",     "comment": "Positional hail sources at openings. Requires EnablePositionalWeather." },
        { "code": "MaxPositionalRainSources",      "type": "integer", "default": 4,      "ingui": "Max Rain Sources",           "comment": "Maximum positional rain source budget. 4 typically covers all openings.",  "range": { "min": 0,      "max": 16,     "step": 1     } },
        { "code": "MaxPositionalWindSources",      "type": "integer", "default": 4,      "ingui": "Max Wind Sources",           "comment": "Maximum positional wind source budget.",                                    "range": { "min": 0,      "max": 16,     "step": 1     } },
        { "code": "MaxPositionalHailSources",      "type": "integer", "default": 4,      "ingui": "Max Hail Sources",           "comment": "Maximum positional hail source budget.",                                    "range": { "min": 0,      "max": 16,     "step": 1     } },
        { "code": "OpeningPersistenceSeconds",     "type": "float",   "default": 10.0,   "ingui": "Opening Persistence (s)",    "comment": "How long openings persist after last verification. Keeps sources active around corners.", "range": { "min": 1.0, "max": 60.0, "step": 1.0 } },
        { "code": "PositionalMinSkyCoverage",      "type": "float",   "default": 0.15,   "ingui": "Min Sky Coverage",           "comment": "Minimum sky coverage before positional sources activate (0-1).",           "range": { "min": 0.0,    "max": 1.0,    "step": 0.05  } },
        { "code": "PositionalWeatherVolume",       "type": "float",   "default": 1.0,    "ingui": "Positional Rain Volume",     "comment": "Volume multiplier for positional rain sources.",                            "range": { "min": 0.0,    "max": 3.0,    "step": 0.05  } },
        { "code": "PositionalWindVolume",          "type": "float",   "default": 0.8,    "ingui": "Positional Wind Volume",     "comment": "Volume multiplier for positional wind sources.",                            "range": { "min": 0.0,    "max": 3.0,    "step": 0.05  } },
        { "code": "PositionalHailVolume",          "type": "float",   "default": 1.0,    "ingui": "Positional Hail Volume",     "comment": "Volume multiplier for positional hail sources.",                            "range": { "min": 0.0,    "max": 3.0,    "step": 0.05  } },

        { "type": "separator", "title": "Thunder" },
        { "code": "EnableThunderPositioning",      "type": "boolean", "default": true,   "ingui": "Enable Thunder Positioning", "comment": "Two-layer positioned thunder. Directional cracks at openings. Requires EnableWeatherEnhancement." },
        { "code": "ThunderLPFMinCutoff",           "type": "float",   "default": 800.0,  "ingui": "Thunder LPF Min Cutoff (Hz)","comment": "Min LPF cutoff for indoor thunder rumble. Lower = deeper, barely-audible rumble.", "range": { "min": 20.0, "max": 4000.0, "step": 10.0 } },
        { "code": "ThunderLayer1Volume",           "type": "float",   "default": 1.0,    "ingui": "Thunder Layer 1 Volume",     "comment": "Volume multiplier for thunder Layer 1 (indoor muffled rumble).",            "range": { "min": 0.0,    "max": 3.0,    "step": 0.05  } },
        { "code": "ThunderLayer2Volume",           "type": "float",   "default": 1.0,    "ingui": "Thunder Layer 2 Volume",     "comment": "Volume multiplier for thunder Layer 2 (positional crack at openings).",    "range": { "min": 0.0,    "max": 3.0,    "step": 0.05  } },
        { "code": "MaxThunderSources",             "type": "integer", "default": 10,     "ingui": "Max Thunder Sources",        "comment": "Maximum positional thunder sources (one-shot pool).",                        "range": { "min": 1,      "max": 32,     "step": 1     } },

        { "type": "separator", "title": "Performance" },
        { "code": "MaxSoundsPerTick",              "type": "integer", "default": 25,     "ingui": "Max Sounds Per Tick",        "comment": "Max sounds running full raycasting per tick. 0=unlimited. Protects against lag spikes.", "range": { "min": 0, "max": 100, "step": 1 } },
        { "code": "MaxOverdueSoundsPerTick",       "type": "integer", "default": 6,      "ingui": "Max Overdue Per Tick",       "comment": "Extra overdue sounds processed on top of MaxSoundsPerTick per tick.",         "range": { "min": 0,      "max": 50,     "step": 1     } },
        { "code": "EnableReverbCellCache",         "type": "boolean", "default": true,   "ingui": "Reverb Cell Cache",          "comment": "Sounds in the same 4x4x4 block area share reverb calculations. Reduces CPU." },
        { "code": "EnableSoundThrottle",           "type": "boolean", "default": true,   "ingui": "Enable Sound Throttle",      "comment": "Limit concurrent positional sounds to save OpenAL mixing overhead." },
        { "code": "MaxConcurrentSounds",           "type": "integer", "default": 40,     "ingui": "Max Concurrent Sounds",      "comment": "Maximum concurrent positional sounds. Farther sounds blocked when over budget.", "range": { "min": 0, "max": 256, "step": 1 } },
        { "code": "ThrottleFadeSeconds",           "type": "float",   "default": 5.0,    "ingui": "Throttle Fade (s)",          "comment": "Fade duration when a sound is throttled/unthrottled. 0=instant cut.",       "range": { "min": 0.0,    "max": 30.0,   "step": 0.5   } },
        { "code": "WeatherTickIntervalMs",         "type": "integer", "default": 100,    "ingui": "Weather Tick Interval (ms)", "comment": "Weather update interval in milliseconds. Lower=smoother but more CPU.",    "range": { "min": 16,     "max": 1000,   "step": 16    } },

        { "type": "separator", "title": "Debug (Developer)" },
        { "code": "DebugMode",                     "type": "boolean", "default": false,  "ingui": "Debug Mode",                 "comment": "Enable debug logging. Shows occlusion results, filter values. Toggle: /soundphysics debug" },
        { "code": "DebugVerbose",                  "type": "boolean", "default": false,  "ingui": "Debug Verbose",              "comment": "Per-block DDA raycast logging. WARNING: 300+ lines per sound per update." },
        { "code": "DebugOcclusion",                "type": "boolean", "default": false,  "ingui": "Debug Occlusion",            "comment": "Debug occlusion raycasting. Shows per-sound results, ray hits, material absorption." },
        { "code": "DebugReverb",                   "type": "boolean", "default": false,  "ingui": "Debug Reverb",               "comment": "Debug reverb analysis. Shows ray hits, material contributions, final values." },
        { "code": "DebugSoundPaths",               "type": "boolean", "default": false,  "ingui": "Debug Sound Paths",          "comment": "Debug sound path resolution. Shows path count, occlusion, repositioning offset." },
        { "code": "DebugResonator",                "type": "boolean", "default": false,  "ingui": "Debug Resonator",            "comment": "Debug resonator features. Shows pause/resume events, Carry On state, boombox state." },
        { "code": "DebugWeather",                  "type": "boolean", "default": false,  "ingui": "Debug Weather",              "comment": "Debug weather audio. Shows enclosure values, LPF gainHF, sound start/stop." },
        { "code": "DebugPositionalWeather",        "type": "boolean", "default": false,  "ingui": "Debug Positional Weather",   "comment": "Debug positional weather. Shows opening tracking, clustering, source placement." },
        { "code": "DebugWeatherVisualization",     "type": "boolean", "default": false,  "ingui": "Debug Weather Visualization","comment": "Visual block highlights showing DDA weather enclosure detection." },
        { "code": "DebugThunder",                  "type": "boolean", "default": false,  "ingui": "Debug Thunder",              "comment": "Debug thunder events. Shows layer decisions, opening selection, bolt scoring." }
    ]
}
